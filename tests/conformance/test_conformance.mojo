    var enc = _load_encoder_o200k()
    var ids = enc.encode("", SpecialPolicy.allow_all())
    assert_equal(len(ids), 0)


def test_o200k_round_trip_all_fixtures() raises:
    """decode(encode(s)) == s for every o200k fixture input."""
    var enc = _load_encoder_o200k()

    var json_mod = Python.import_module("json")
    var f = open("tests/conformance/o200k_fixtures.json", "r")
    var fixture = json_mod.loads(f.read())
    var cases = fixture["cases"]
    var n_cases = Int(py=len(cases))

    for i in range(n_cases):
        var case_ = cases[i]
        var input_str = String(py=case_["input"])
        var ids = enc.encode(input_str, SpecialPolicy.allow_all())
        var back = enc.decode(ids)
        assert_equal(back, input_str)


def main() raises:
    TestSuite.discover_tests[__functions_in_module()]().run()
